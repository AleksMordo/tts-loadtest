services:
  dcgm-exporter:
    # nvcr.io отдаёт 403 из сетей YC (2026-07-04, любой тег) — берём официальное
    # зеркало с Docker Hub. Метрики отчёта (DCGM_FI_DEV_GPU_UTIL/FB_USED)
    # в 4.x остались в дефолтном наборе.
    image: docker.io/nvidia/dcgm-exporter:4.5.2-4.8.1-ubuntu22.04
    restart: unless-stopped
    user: "0:0"          # dcgm host engine требует root внутри контейнера
    cap_add:
      - SYS_ADMIN        # профилировочные метрики DCGM
    ports:
      - "{{ dcgm_exporter_port }}:9400"
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]

  node-exporter:
    image: prom/node-exporter:v1.8.2
    restart: unless-stopped
    network_mode: host
    pid: host
    command:
      - "--path.rootfs=/host"
    volumes:
      - /:/host:ro,rslave
